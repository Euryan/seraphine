{
  "name": "seraphine-final-workspace",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n WEB,ADMIN,API -c cyan,magenta,green \"npm:dev:web\" \"npm:dev:admin\" \"npm:dev:backend\"",
    "dev:web": "npm --prefix web run dev",
    "dev:admin": "npm --prefix admin run dev",
    "dev:backend": "node scripts/run-backend.cjs",
    "build": "npm run build:web && npm run build:admin",
    "build:web": "npm --prefix web run build",
    "build:admin": "npm --prefix admin run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}